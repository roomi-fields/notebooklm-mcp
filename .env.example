# NotebookLM MCP example configuration
# Copy to .env and adjust only what you need.

# Optional: target a specific notebook for local HTTP checks
NOTEBOOK_URL=https://notebooklm.google.com/notebook/<your-notebook-id>

# HTTP server
HTTP_HOST=127.0.0.1
HTTP_PORT=3000
NODE_ENV=production

# Browser automation
HEADLESS=true
STEALTH_ENABLED=true
NOTEBOOKLM_UI_LOCALE=en

# Session handling
MAX_SESSIONS=10
SESSION_TIMEOUT=900

# Persistent data
DATA_DIR=./Data
CHROME_PROFILE_DIR=./Data/chrome_profile
BROWSER_STATE_DIR=./Data/browser_state
